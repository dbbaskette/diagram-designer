{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:with-proxy": "concurrently \"npm run dev\" \"npm run proxy\"",
    "proxy": "cd ../diagram-designer-api && ../mvnw spring-boot:run",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "setup": "npm install",
    "start:full": "npm run setup && npm run dev:with-proxy"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.0.0",
    "@tanstack/react-query": "^5.85.9",
    "axios": "^1.11.0",
    "html-to-image": "^1.11.13",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "dompurify": "^3.2.4",
    "marked": "^15.0.6",
    "@dagrejs/dagre": "^1.1.4",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/dompurify": "^3.2.0",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.1",
    "vite": "^7.1.2"
  }
